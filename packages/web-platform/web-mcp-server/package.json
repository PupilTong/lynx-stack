{
  "name": "@lynx-js/web-mcp-server",
  "version": "0.0.1",
  "private": true,
  "description": "A MCP tool for AI to inspect lynx pages",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/mcp/index.js",
  "bin": {
    "lynx-web-mcp-tool": "dist/mcp/index.js"
  },
  "scripts": {
    "build": "npm run build:web && npm run build:mcp",
    "build:mcp": "rslib build",
    "build:web": "rsbuild build",
    "preinstall": "npx puppeteer browsers install chrome"
  },
  "dependencies": {
    "puppeteer": "24.22.0"
  },
  "devDependencies": {
    "@lynx-js/web-core": "workspace:*",
    "@lynx-js/web-elements": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.18.0",
    "@rstest/core": "^0.4.0",
    "rsbuild-plugin-arethetypeswrong": "0.1.1",
    "rsbuild-plugin-publint": "0.3.3",
    "zod": "^3.25.76"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
